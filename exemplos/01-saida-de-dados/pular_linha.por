programa{
	funcao inicio(){
		// O \n serve para "empurrar" o texto para a linha de baixo (como se apertasse a tecla Enter).
		escreva("Olá!\n") 
		escreva("Esta frase aparecerá na segunda linha.\n")
		
		escreva("\n") // Cria uma linha totalmente em branco
		
		escreva("Podemos também colocar várias \nquebras\n de\n linha\n na mesma instrução!")
	}
}
