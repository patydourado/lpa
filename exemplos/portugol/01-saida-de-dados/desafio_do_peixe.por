programa{
	funcao inicio()	{
		escreva("      DESAFIO DO PEIXE \n")
		escreva("    ==================== \n\n")

		/* Observe as barras duplas \\ - elas são necessárias para o computador
		 entender que queremos exibir UMA barra invertida na tela. Se usar apenas
     uma \ o computador acha que vai usar um caractere especial como \n .  */

		escreva("            ___    \n")
		escreva("        |\\/   O\\  \n")
		escreva("        |/\\____/   \n")
	}
}
